# Dashboard header
NEXT_PUBLIC_DASHBOARD_NAME=GANYMEDE · HOME
NEXT_PUBLIC_DASHBOARD_LOCATION=Brookline, Mass.

# Open-Meteo is keyless; set your coordinates
WEATHER_LAT=40.7128
WEATHER_LON=-74.0060
WEATHER_TZ=America/New_York

# Optional. Calendar can also be set from the Settings gear at runtime.
# When set here, this overrides the UI value.
#GOOGLE_CALENDAR_ICS_URL=

# Optional. Photos can also be set from the Settings gear (iCloud shared album).
# When set to a directory that exists, this overrides the UI value.
#PHOTOS_DIR=/home/pi/ganymede-photos
