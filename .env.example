# Dashboard header
NEXT_PUBLIC_DASHBOARD_NAME=GANYMEDE · HOME
NEXT_PUBLIC_DASHBOARD_LOCATION=Brookline, Mass.

# Open-Meteo is keyless; set your coordinates
WEATHER_LAT=40.7128
WEATHER_LON=-74.0060
WEATHER_TZ=America/New_York

# Google OAuth for Calendar (read) + Tasks (read/write).
# Create an OAuth 2.0 client in Google Cloud Console — see README.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# Optional. Apple Calendar can also be set from the Settings gear or the
# Calendar widget's setup card. When set, this overrides the UI value.
#APPLE_CALENDAR_ICS_URL=webcal://p98-caldav.icloud.com/published/2/...

# Optional. Photos can also be set from the Settings gear (iCloud shared album).
# When set to a directory that exists, this overrides the UI value.
#PHOTOS_DIR=/home/pi/ganymede-photos
