# Dashboard header
NEXT_PUBLIC_DASHBOARD_NAME=GANYMEDE · HOME
NEXT_PUBLIC_DASHBOARD_LOCATION=Brookline, Mass.

# Open-Meteo is keyless; set your coordinates
WEATHER_LAT=40.7128
WEATHER_LON=-74.0060
WEATHER_TZ=America/New_York

# Google Calendar: use the "secret address in iCal format" from calendar settings
GOOGLE_CALENDAR_ICS_URL=

# Absolute path on the Pi where JPG/PNG photos live
PHOTOS_DIR=/home/pi/ganymede-photos
